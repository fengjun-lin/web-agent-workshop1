# Copy this file to `.env` and fill in your key:  cp .env.example .env
#
# --- Option A: OpenAI (default) ---
OPENAI_API_KEY=sk-your-key-here
# gpt-4.1-mini is a good pick: smart + fast + cheap, and (unlike gpt-5.x reasoning
# models) it supports the `stop` param + custom temperature this ReAct loop uses.
MODEL=gpt-4.1-mini
#
# --- Option B: GitHub Models (free, OpenAI-compatible) ---
# Get a token at https://github.com/settings/tokens (no extra scope needed).
# OPENAI_API_KEY=ghp_your_github_token
# OPENAI_BASE_URL=https://models.github.ai/inference
# MODEL=openai/gpt-4o-mini
#
# --- Option C: MiniMax (OpenAI-compatible) ---
# OPENAI_API_KEY=your-minimax-key
# OPENAI_BASE_URL=https://api.minimax.io/v1
# MODEL=MiniMax-M3
